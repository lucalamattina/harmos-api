# --- Local Development Configuration (Example) ---
# Copy this file to application-local.properties and fill in real values.
# NEVER commit application-local.properties — it is listed in .gitignore.

spring.datasource.url=jdbc:postgresql://localhost:5432/harmos-db
spring.datasource.username=CHANGE_ME
spring.datasource.password=CHANGE_ME
spring.jpa.hibernate.ddl-auto=create-drop

# Email Configuration
spring.mail.username=CHANGE_ME@gmail.com
spring.mail.password=CHANGE_ME
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Frontend URL for local development
app.frontend.url=http://localhost:3000

# Database Repopulation
app.database.repopulate=true

#Logs
# Disable Hibernate SQL logging
spring.jpa.show-sql=false
logging.level.org.hibernate.SQL=OFF
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=OFF

# Enable request/application logs
logging.level.org.springframework.web=DEBUG
logging.level.root=INFO
