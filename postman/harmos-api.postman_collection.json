{
	"info": {
		"_postman_id": "harmos-api-collection",
		"name": "Harmos API",
		"description": "Collection for Harmos API endpoints including email service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Email Service",
			"item": [
				{
					"name": "Send Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"to\": \"recipient@example.com\",\n    \"subject\": \"Test Email\",\n    \"body\": \"This is a test email from Harmos API\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/messages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"messages"
							]
						},
						"description": "Send an email to a specified recipient"
					},
					"response": []
				},
				{
					"name": "Get Message Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/messages/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"messages",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "message-id-here",
									"description": "The ID of the message to check"
								}
							]
						},
						"description": "Get the status of a previously sent message"
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		}
	]
} 